# 医院 WAF MCP — 魔搭 / 远程部署（Streamable HTTP）
# 构建: docker build -f Dockerfile.mcp -t hospital-waf-mcp .
# 运行: docker run -p 8000:8000 hospital-waf-mcp

FROM python:3.11-slim

LABEL org.opencontainers.image.title="医院WAF-MCP"
LABEL org.opencontainers.image.version="1.0.0"

WORKDIR /app

COPY pyproject.toml .
COPY README.md .
COPY LICENSE .
COPY waf_mcp/ ./waf_mcp/

RUN pip install --no-cache-dir -e .

ENV WAF_MCP_TRANSPORT=http
ENV WAF_MCP_HOST=0.0.0.0
ENV WAF_MCP_PORT=8000

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import httpx; httpx.get('http://localhost:8000/health')" || exit 1

CMD ["python", "-m", "waf_mcp"]
